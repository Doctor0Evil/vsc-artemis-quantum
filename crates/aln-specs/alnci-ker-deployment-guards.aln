alnspec v1.0 alnci-ker-deployment-guards
description Global CI/deployment invariants for corridor, KER, and quantum orthogonality
version 2026.03.28
owneralnid bostrom18sd2ujv24ual9c9pshtxys6j8knh6xaead9ye7

invariant nocorridornobuild
  description All planes must have corridor tables present
  predicate corridorstable_present
    expr EXISTS(corridortable) FOR ALL planes
  ensures nocorridornobuild
endinvariant

invariant kerdeployable
  description K >= 0.90, E >= 0.90, R <= 0.13 for PRODUCTION lanes
  predicate ker_thresholds
    expr K >= 0.90 && E >= 0.90 && R <= 0.13
  applies_to PRODUCTION
  ensures kerdeployable
endinvariant

invariant quantumnoninterferencerequired
  description quantumorthogonalok must hold for any artifact entering PRODUCTION
  predicate quantum_orthogonal
    expr quantumorthogonalok == true
  applies_to PRODUCTION
  ensures quantumnoninterferencerequired
endinvariant

environment RESEARCH
  corridor_caps loose
  orthogonality optional
  vt_checks required
endenvironment

environment PILOT
  corridor_caps tight
  orthogonality required_for_identity_lanes
  vt_checks required
endenvironment

environment PRODUCTION
  corridor_caps strict
  orthogonality required
  vt_checks required
  nocorridornobuild required
  kerdeployable required
  quantumnoninterferencerequired required
  no_bypass true
endenvironment
